{
  "exclude": ["webpack.config.js", "node_modules/", "dist/"],
  // exclude表示排除的文件或文件夹，默认是node_modules、bower_components、jspm_packages和<outDir>指定的文件夹
  // Visit https://aka.ms/tsconfig to read more about this file
  "compilerOptions": {
    // File Layout
    // "rootDir": "./src",    // "outDir": "./dist",

    // Environment Settings
    // See also https://aka.ms/tsconfig/module
    "module": "es6",
    "target": "es6",
    "rootDir": "./src",
    // 用来指定编译后文件所在目录
    "outDir": "./dist",
    // 全局作用域中的代码，会全部合并为一个文件，适合浏览器环境
    // "outFile": "./dist/app.js",
    "types": [],
    // For nodejs:
    // "lib": ["esnext"],
    // "types": ["node"],
    // and npm install -D @types/node

    // Other Outputs
    "sourceMap": false,
    "declaration": true,
    "declarationMap": true,

    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // Style Options
    // "noImplicitReturns": true,
    // "noImplicitOverride": true,
    // "noUnusedLocals": true,
    // "noUnusedParameters": true,
    // "noFallthroughCasesInSwitch": true,
    // "noPropertyAccessFromIndexSignature": true,

    // Recommended Options
    // 启用所有严格类型检查选项
    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,
    // 是否编译JS文件
    "allowJs": true,
    // 不生成编译后的文件
    "noEmit": false,
    // 当有错误时不编译生成后的文件
    "noEmitOnError": true,
    // 不允许隐式的any类型
    "noImplicitAny": true,
      // 不允许在没有明确类型的情况下使用this
    "noImplicitThis": true,
    // 严格的检查空值
    "strictNullChecks": true,
  }
}
